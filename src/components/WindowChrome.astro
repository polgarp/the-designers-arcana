---
// The "desktop-app-window" frame — the card border made into UI chrome.
// Double navy rule, brandmark (links home) left, About link right.
import { withBase } from '../lib/url';

interface Props {
  brand?: string;
  version?: string;
  tagline?: string;
  tall?: boolean;   // fixed-viewport window: body scrolls, footer pins to bottom
}
const {
  brand = "The Designer's Arcana",
  version = 'v0.1',
  tagline = 'A working designer’s tarot.',
  tall = false,
} = Astro.props;
const hasFooter = Astro.slots.has('footer');
---

<section class:list={['window', { 'window--tall': tall }]}>
  <header class="bar">
    <a class="brand" href={withBase()}>
      <svg class="lozenge" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M8 1 L15 8 L8 15 L1 8 Z" fill="none" stroke="var(--house)" stroke-width="1.2" />
        <path d="M8 4.5 L11.5 8 L8 11.5 L4.5 8 Z" fill="var(--house)" />
      </svg>
      <span class="brand__name t-display">{brand}</span>
      <span class="brand__ver">{version}</span>
      <span class="brand__sep" aria-hidden="true">/</span>
      <span class="brand__tag t-italic">{tagline}</span>
    </a>
    <a class="about" href={withBase('about/')}>About</a>
  </header>
  <div class="rule" aria-hidden="true"></div>
  <div class="window__body">
    <slot />
  </div>
  {hasFooter && (
    <div class="window__footer">
      <slot name="footer" />
    </div>
  )}
</section>

<style>
  .window {
    position: relative;
    background: var(--cream);
    border: var(--rule) solid var(--ink);
    padding: clamp(0.9rem, 2vw, 1.5rem);
    /* the frame fills the viewport (an app window) so per-page footers —
       e.g. the card pager — land at a consistent place regardless of how
       much content sits above them */
    min-height: calc(100svh - 2 * clamp(1rem, 3vw, 2.5rem));
    display: flex;
    flex-direction: column;
  }
  /* fixed-viewport app window: an inner region scrolls, footer pins down */
  .window--tall {
    height: calc(100svh - 2 * clamp(1rem, 3vw, 2.5rem));
    min-height: 0;
  }
  /* clip vertically (keeps the fixed-height layout) but let horizontal
     overflow show, so the card's drop-shadow isn't sheared on the right */
  .window--tall .window__body { overflow-x: visible; overflow-y: clip; min-height: 0; }
  .window__footer { flex: none; }
  /* second, inset rule → Deco double-line */
  .window::after {
    content: '';
    position: absolute;
    inset: 5px;
    border: var(--hairline) solid var(--ink);
    pointer-events: none;
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.1rem 0.4rem 0.7rem;
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    min-width: 0;
    text-decoration: none;
  }
  .lozenge { width: 16px; height: 16px; align-self: center; flex: none; }
  .brand__name {
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    letter-spacing: var(--name-tracking);
    color: var(--ink);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .brand__ver {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--house);
    text-transform: uppercase;
  }
  .brand__sep { color: var(--ink-30); font-family: var(--font-ui); }
  .brand__tag {
    font-size: 0.82rem;
    color: var(--ink-60);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .about {
    flex: none;
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.66rem;
    color: var(--ink-60);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color 140ms ease, border-color 140ms ease;
  }
  .about:hover { color: var(--house); border-bottom-color: var(--house); }

  .rule { height: var(--hairline); background: var(--ink); opacity: 0.85; }
  .window__body {
    padding-top: clamp(1rem, 2.4vw, 1.8rem);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 640px) {
    .brand__sep, .brand__tag { display: none; }
  }
  /* on small screens, let the tall window grow and the page scroll normally */
  @media (max-width: 720px) {
    .window--tall { height: auto; min-height: calc(100svh - 2 * clamp(1rem, 3vw, 2.5rem)); }
    .window--tall .window__body { overflow: visible; }
  }
</style>
