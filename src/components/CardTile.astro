---
// A card in the gallery / detail stage.
//   illustrated → the composed plate (face up), links to its detail page
//   not yet      → the card back (face down); secret, no name.
// In dev, un-illustrated cards stay clickable so the detail layout can be
// reviewed; in the production build they have no detail page at all.
import CardBack from './CardBack.astro';

interface Props {
  name: string;
  suit?: string | null;
  ready?: boolean;
  artHref?: string | null;
  backHref?: string | null;   // real synced _back.svg, if present
  href?: string;
  transitionName?: string;    // shared name → morphs gallery tile ↔ detail card
}
const { name, suit = null, ready = false, artHref, backHref, href, transitionName } = Astro.props;

const dev = import.meta.env.DEV;
const linkable = href && (ready || dev);
const Tag = linkable ? 'a' : 'div';
---

<Tag
  class="tile"
  data-ready={String(ready)}
  data-arcana={suit ? 'minor' : 'major'}
  data-suit={suit ?? 'none'}
  href={linkable ? href : undefined}
  role={linkable ? undefined : 'img'}
  aria-label={ready ? name : 'Unrevealed card'}
  transition:name={transitionName}
>
  {ready && artHref ? (
    <img class="tile__plate" src={artHref} alt={name} loading="lazy" />
  ) : backHref ? (
    <img class="tile__plate" src={backHref} alt="Card back" loading="lazy" />
  ) : (
    <CardBack />
  )}
</Tag>

<style>
  .tile {
    position: relative;
    aspect-ratio: 300 / 450;
    width: 100%;
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 160ms ease;
  }
  a.tile { cursor: pointer; }
  a.tile:hover { transform: translateY(-3px); }
  a.tile:focus-visible { outline: 2px solid var(--house); outline-offset: 4px; }
  .tile__plate { width: 100%; height: 100%; object-fit: contain; display: block; }
</style>
