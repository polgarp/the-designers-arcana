---
// Global layout: loads the three candidate type systems + tokens.
// Fontsource CSS is imported here so every page shares one font load.
import '@fontsource/fraunces/400.css';
import '@fontsource/fraunces/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/spectral/400-italic.css';
import '../styles/tokens.css';

interface Props {
  title?: string;
}
const { title = "The Designer's Arcana" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
