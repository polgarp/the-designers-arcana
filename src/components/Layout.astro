---
// Global layout: loads the three candidate type systems + tokens.
// Fontsource CSS is imported here so every page shares one font load.
import '@fontsource/marcellus/400.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/spectral/400-italic.css';
import '../styles/tokens.css';
import { ViewTransitions } from 'astro:transitions';

import { SITE } from '../config';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
  image?: string;     // absolute or base-relative OG image
  canonical?: string;
}
const {
  title = SITE.name,
  description = SITE.description,
  image,
  canonical,
} = Astro.props;

// card pages pass their own image; everything else falls back to the
// site-level OG so a shared homepage/motif link still unfurls with art.
const ogImage = image ?? new URL(withBase('og/home.png'), Astro.site).href;
const favicon = withBase('favicon.svg');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  // Give prev/next navigation a direction so the slide transition reverses:
  // clicking "next" slides forward, "prev" slides back.
  let pagerDir: string | null = null;
  document.addEventListener(
    'click',
    (e) => {
      const a = (e.target as HTMLElement)?.closest?.('[data-pager]') as HTMLElement | null;
      pagerDir = a ? a.dataset.pager ?? null : null;
    },
    true,
  );
  document.addEventListener('astro:before-preparation', (e: any) => {
    if (pagerDir === 'prev') e.direction = 'back';
    else if (pagerDir === 'next') e.direction = 'forward';
  });
  document.addEventListener('astro:after-swap', () => {
    pagerDir = null;
  });
</script>
