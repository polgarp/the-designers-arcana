---
// Bottom process strip — how much of the deck is illustrated.
// Overall count + per-group tick bars (Major + four suits).
import { progress } from '../lib/cards';
import { SUITS, suitOrderList } from '../config';

const bars = [
  { label: 'Major', ...progress.majors, color: 'var(--house)' },
  ...suitOrderList.map((s) => ({ label: SUITS[s].label, ...progress.suits[s], color: SUITS[s].color })),
];
const pct = Math.round((progress.all.ready / progress.all.total) * 100);
---

<footer class="strip">
  <div class="strip__count">
    <span class="strip__num t-display">{progress.all.ready}</span>
    <span class="strip__of label">/ {progress.all.total} revealed</span>
    <span class="strip__pct label">{pct}%</span>
  </div>

  <div class="strip__bars">
    {bars.map((b) => (
      <div class="bar" style={`--c:${b.color}`}>
        <span class="bar__label label">{b.label}</span>
        <span class="bar__track" role="img" aria-label={`${b.ready} of ${b.total}`}>
          <span class="bar__fill" style={`width:${(b.ready / b.total) * 100}%`}></span>
        </span>
        <span class="bar__n label">{b.ready}/{b.total}</span>
      </div>
    ))}
  </div>
</footer>

<style>
  .strip {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--ink);
    margin-top: 2rem;
    padding-top: 1.1rem;
  }
  .strip__count { display: flex; align-items: baseline; gap: 0.5rem; }
  .strip__num { font-size: 1.6rem; color: var(--ink); line-height: 1; }
  .strip__of { font-size: 0.7rem; }
  .strip__pct { color: var(--house); }

  .strip__bars { display: flex; gap: 1.4rem; flex-wrap: wrap; }
  .bar { display: grid; grid-template-columns: auto 70px auto; align-items: center; gap: 0.5rem; }
  .bar__label { font-size: 0.6rem; }
  .bar__track {
    height: 4px;
    background: var(--ink-30);
    position: relative;
    display: block;
  }
  .bar__fill { position: absolute; inset: 0 auto 0 0; background: var(--c); }
  .bar__n { font-size: 0.6rem; color: var(--ink-60); }

  @media (max-width: 720px) {
    .strip__bars { gap: 0.8rem 1.2rem; }
  }
</style>
