---
import CardTile from './CardTile.astro';

interface Card {
  name: string;
  traditional_name: string;
  arcana: string;
  suit?: string | null;
  numeral: string;
  domain?: string;
  upright_meaning: string;
  reversed_meaning: string;
  flavor_text: string;
  keywords: string[];
  ready?: boolean;
  artHref?: string | null;
  backHref?: string | null;
}
const { card } = Astro.props as { card: Card };
const arcanaLabel =
  card.arcana === 'major'
    ? 'Major Arcana'
    : `${card.suit ? card.suit[0].toUpperCase() + card.suit.slice(1) : ''}`;
---

<div class="reading">
  <!-- LEFT RAIL: metadata -->
  <aside class="rail rail--left">
    <div class="field">
      <span class="label">Arcana</span>
      <span class="field__val t-name">{arcanaLabel}</span>
    </div>
    <div class="field">
      <span class="label">Number</span>
      <span class="field__val t-display">{card.numeral}</span>
    </div>
    <div class="field">
      <span class="label">Traditional</span>
      <span class="field__val t-name">{card.traditional_name}</span>
    </div>
    {card.domain && (
      <div class="field">
        <span class="label">Domain</span>
        <span class="field__val t-name">{card.domain}</span>
      </div>
    )}
    <div class="field">
      <span class="label">Keywords</span>
      <ul class="chips">
        {card.keywords.map((k) => <li class="chip">{k}</li>)}
      </ul>
    </div>
  </aside>

  <!-- CENTER: the card -->
  <div class="stage">
    <CardTile
      name={card.name}
      suit={card.suit}
      ready={card.ready}
      artHref={card.artHref}
      backHref={card.backHref}
    />
  </div>

  <!-- RIGHT RAIL: the reading -->
  <aside class="rail rail--right">
    <div class="field">
      <span class="label">Upright</span>
      <p class="field__body t-name">{card.upright_meaning}</p>
    </div>
    <div class="field">
      <span class="label">Reversed</span>
      <p class="field__body t-name">{card.reversed_meaning}</p>
    </div>
    <div class="field field--quote">
      <span class="quote-mark" aria-hidden="true">✦</span>
      <p class="field__quote t-italic">{card.flavor_text}</p>
    </div>
  </aside>
</div>

<style>
  .reading {
    display: grid;
    grid-template-columns: 1fr minmax(180px, 240px) 1.2fr;
    gap: clamp(1rem, 3vw, 2.4rem);
    align-items: start;
  }
  .rail { display: flex; flex-direction: column; gap: 1.1rem; }
  .rail--left { padding-top: 0.5rem; }
  .field { display: flex; flex-direction: column; gap: 0.35rem; }
  .field__val {
    font-size: 1rem;
    color: var(--ink);
    line-height: 1.25;
  }
  .field__body {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--ink);
  }
  .chips { list-style: none; margin: 0.1rem 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .chip {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--ink-60);
    border: 1px solid var(--ink-30);
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
  }
  /* one chip carries the suit enamel cell */
  .chip:first-child { border-color: var(--house); color: var(--house); }

  .stage { align-self: start; }

  .field--quote {
    position: relative;
    border-top: 1px solid var(--ink-30);
    padding-top: 1rem;
    margin-top: 0.3rem;
  }
  .quote-mark { color: var(--house); font-size: 0.8rem; }
  .field__quote {
    margin: 0.3rem 0 0;
    font-size: 1.04rem;
    line-height: 1.45;
    color: var(--ink-60);
  }

  @media (max-width: 760px) {
    .reading { grid-template-columns: 1fr; }
    .stage { max-width: 240px; margin: 0 auto; order: -1; }
  }
</style>
