---
import Layout from '../components/Layout.astro';
import WindowChrome from '../components/WindowChrome.astro';
import CardTile from '../components/CardTile.astro';
import ReadingLayout from '../components/ReadingLayout.astro';

// Real deck data (from product-design-tarot/data/cards.json) so the
// specimen reads true. Mix of arcana + all four suit accents + a long
// name to stress-test wrapping.
const researcher = {
  name: 'The Researcher',
  traditional_name: 'The High Priestess',
  arcana: 'major',
  suit: null,
  numeral: 'II',
  domain: 'Insight / User truth',
  upright_meaning:
    'Knows what users actually do, not what they say they do. Holder of uncomfortable truths gathered in dimly-lit interview rooms.',
  reversed_meaning:
    'Sitting on insights nobody reads. Truth held too long becomes folklore.',
  flavor_text:
    'Asked one user a single follow-up question and now the entire roadmap is on hold.',
  keywords: ['insight', 'intuition', 'user-truth', 'patience', 'evidence'],
};

const gallery = [
  { name: 'The Junior', numeral: '0', suit: null },
  { name: 'The Design Systems Lead', numeral: 'III', suit: null },
  { name: 'The Workshop', numeral: 'II', suit: 'pencils' },
  { name: 'The Senior Researcher', numeral: 'QUEEN', suit: 'mugs' },
  { name: 'The Eng Manager', numeral: 'KING', suit: 'cursors' },
  { name: 'The Stretch', numeral: 'X', suit: 'pixels' },
];

const systems = [
  {
    cls: 'sys-engraved',
    label: 'A · Engraved Atelier',
    spec: 'Cinzel · Playfair Display · IBM Plex Mono · Newsreader Italic',
    note: 'Engraved devotional plate — closest to the researcher-v41 render. Most mystical.',
  },
  {
    cls: 'sys-deco',
    label: 'B · Deco Modern',
    spec: 'Marcellus · Inter · Newsreader Italic',
    note: 'Deco-architectural, product-forward, lighter on mysticism. “A designer thing.”',
  },
  {
    cls: 'sys-studio',
    label: 'C · Studio Manual',
    spec: 'Fraunces (Display) · IBM Plex Mono (UI) · Spectral Italic',
    note: 'Technical manual plate, mono-led, restrained. On-doctrine “pencil note” voice.',
  },
];
---

<Layout title="Style tile — choose the deck's voice">
  <main class="page">
    <header class="page__head">
      <h1>The Designer’s Arcana — style tile</h1>
      <p>
        Three candidate type systems, same chrome and data. Pick the deck’s
        voice by eye; the winner becomes the default and these panels are
        removed.
      </p>
    </header>

    {systems.map((sys) => (
      <section class={`specimen ${sys.cls}`}>
        <div class="specimen__tag">
          <span class="specimen__label">{sys.label}</span>
          <span class="specimen__spec">{sys.spec}</span>
          <span class="specimen__note">{sys.note}</span>
        </div>

        <WindowChrome>
          <div class="mini-gallery">
            {gallery.map((c) => (
              <CardTile name={c.name} numeral={c.numeral} suit={c.suit} />
            ))}
          </div>
          <div class="reading-wrap">
            <ReadingLayout card={researcher} />
          </div>
        </WindowChrome>
      </section>
    ))}
  </main>
</Layout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1rem, 3vw, 2rem) 5rem;
  }
  .page__head { margin-bottom: 2.5rem; max-width: 60ch; }
  .page__head h1 {
    font-family: var(--font-name);
    font-weight: 600;
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    letter-spacing: 0.02em;
    margin: 0 0 0.6rem;
  }
  .page__head p {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-60);
    margin: 0;
  }

  .specimen { margin-bottom: 4rem; }
  .specimen__tag {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1rem;
    padding-left: 0.2rem;
    border-left: 3px solid var(--house);
    padding-left: 0.8rem;
  }
  .specimen__label {
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink);
  }
  .specimen__spec {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--house);
  }
  .specimen__note {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--ink-60);
  }

  .mini-gallery {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: clamp(0.6rem, 1.4vw, 1.1rem);
    margin-bottom: 2.4rem;
  }
  .reading-wrap {
    border-top: 1px solid var(--ink-30);
    padding-top: 2rem;
  }

  @media (max-width: 880px) {
    .mini-gallery { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .mini-gallery { grid-template-columns: repeat(2, 1fr); }
  }
</style>
