---
import Layout from '../../components/Layout.astro';
import WindowChrome from '../../components/WindowChrome.astro';
import CardTile from '../../components/CardTile.astro';
import { detailCards, type Card } from '../../lib/cards';
import { SITE } from '../../config';
import { withBase } from '../../lib/url';
import { keywordThread } from '../../themes';

export function getStaticPaths() {
  const list = detailCards;
  return list.map((card, i) => ({
    params: { id: card.id },
    props: {
      card,
      prev: list[(i - 1 + list.length) % list.length],
      next: list[(i + 1) % list.length],
    },
  }));
}

const { card, prev, next } = Astro.props as { card: Card; prev: Card; next: Card };
const canonical = new URL(withBase(`cards/${card.id}/`), Astro.site).href;
const ogImg = new URL(withBase(`og/${card.id}.png`), Astro.site).href;
const shareImg = withBase(`share/${card.id}.png`);

// The synced content's `name` is already just the card's proper title (no
// rank/suit prefix to strip — see lib/cards.ts's rankOfSuit for that).
const arcanaLabel = card.arcana === 'major' ? `Major Arcana · ${card.numeral}` : card.rankOfSuit;
// Subtitle points to the real tarot card it descends from (not the suit
// domain, which only repeats the eyebrow's suit name).
const sub = `after ${card.traditional_name}`;

// Small directional slide for the reading text on prev/next. Clipped to
// the scroll column, so nothing travels past the frame or below the fold.
const slideText = {
  forwards: {
    old: { name: 'da-out-left', duration: '0.24s', easing: 'ease-in', fillMode: 'both' },
    new: { name: 'da-in-right', duration: '0.28s', easing: 'ease-out', fillMode: 'both' },
  },
  backwards: {
    old: { name: 'da-out-right', duration: '0.24s', easing: 'ease-in', fillMode: 'both' },
    new: { name: 'da-in-left', duration: '0.28s', easing: 'ease-out', fillMode: 'both' },
  },
};

// The card art carries its own view-transition-name (card-<id>, shared
// with its gallery tile — that's what lets a gallery click morph into the
// detail hero). Between two *different* card pages that name never
// matches, so old/new are an unmatched pair with no size/position to
// morph between — just the same slide as the text, gated to pager clicks
// via html[data-card-pager] (see Layout.astro's astro:after-swap).
// `::view-transition-old/new()` takes only a literal name or the
// universal `*` — no wildcard — and `*` would also catch the root and
// text transitions (equal specificity, so whichever rule loads last
// wins — not reliably ours). Enumerating every card's exact name avoids
// that collision entirely.
const cardScopeCSS = (() => {
  const names = detailCards.map((c) => `card-${c.id}`);
  const rule = (dir: 'next' | 'prev', pseudo: 'old' | 'new', anim: string) =>
    names.map((n) => `html[data-card-pager="${dir}"]::view-transition-${pseudo}(${n})`).join(',') +
    `{animation:${anim} both}`;
  return [
    rule('next', 'old', 'da-out-left 0.24s ease-in'),
    rule('next', 'new', 'da-in-right 0.28s ease-out'),
    rule('prev', 'old', 'da-out-right 0.24s ease-in'),
    rule('prev', 'new', 'da-in-left 0.28s ease-out'),
  ].join('\n');
})();
---

<style set:html={cardScopeCSS}></style>

<Layout
  title={`${card.name} · ${SITE.name}`}
  description={card.upright_meaning}
  image={ogImg}
  canonical={canonical}
>
  <main class="shell">
    <WindowChrome tall>
      <div class="detail">
        <a class="back" href={withBase()}>← All cards</a>

        <div class="cols">
          <!-- LEFT: the reading (scrolls; slides on prev/next) -->
          <div class="read" transition:animate={slideText}>
            <header class="chead">
              <span class="chead__eyebrow label">{arcanaLabel}</span>
              <h1 class="chead__name t-name">{card.name}</h1>
              <p class="chead__sub t-italic">{sub}</p>
            </header>

            <div class="rblock">
              <span class="label">Upright</span>
              <p class="rblock__body">{card.upright_meaning}</p>
            </div>
            <div class="rblock">
              <span class="label">Reversed</span>
              <p class="rblock__body">{card.reversed_meaning}</p>
            </div>

            <blockquote class="flavor">
              <span class="flavor__mark" aria-hidden="true">✦</span>
              <p class="t-italic">{card.flavor_text}</p>
            </blockquote>

            <section class="why">
              <span class="label">The parallel</span>
              <p class="why__body t-name">{card.fit_rationale}</p>
            </section>

            {card.ready && (
              <figure class="share">
                <img class="share__img" src={shareImg} alt={`${card.name} — shareable card`} width="170" height="213" loading="lazy" />
                <figcaption class="share__copy">
                  <span class="label">Share this card</span>
                  <span class="share__hint">Right-click or long-press to save — the page link travels with it.</span>
                </figcaption>
              </figure>
            )}
          </div>

          <!-- RIGHT: the card (stays in place), with its keyword tags -->
          <aside class="cardcol">
            <button class="cardzoom" type="button" aria-label="Zoom in on the card">
              <CardTile
                name={card.name}
                suit={card.suit}
                ready={card.ready}
                artHref={card.artHref}
                backHref={card.backHref}
                transitionName={`card-${card.id}`}
              />
              <span class="cardzoom__hint" aria-hidden="true">⤢ Zoom</span>
            </button>
            <ul class="kw" aria-label="Keywords — tap to explore related cards">
              {card.keywords.map((k, i) => (
                <li>
                  <a
                    class:list={['kw-tag', { 'kw-tag--lead': i === 0 }]}
                    href={withBase(`themes/${keywordThread(k) ?? card.threads[0]}/`)}
                  >{k}</a>
                </li>
              ))}
            </ul>
          </aside>

          <dialog class="lightbox" aria-label={`${card.name} — enlarged`}>
            <button class="lightbox__close" type="button" aria-label="Close">✕</button>
            <img class="lightbox__img" src={card.artHref ?? card.backHref} alt={card.name} />
          </dialog>
        </div>
      </div>

      <nav slot="footer" class="pager" aria-label="Card navigation">
        <a class="pager__link" href={withBase(`cards/${prev.id}/`)} data-pager="prev" rel="prev">
          <span class="label">Prev</span>
          <span class="pager__name t-name">← {prev.name}</span>
        </a>
        <a class="pager__link pager__link--next" href={withBase(`cards/${next.id}/`)} data-pager="next" rel="next">
          <span class="label">Next</span>
          <span class="pager__name t-name">{next.name} →</span>
        </a>
      </nav>
    </WindowChrome>
  </main>
</Layout>

<script>
  // Fade the reading column's top edge in only once it's scrolled.
  function initReadFade() {
    const read = document.querySelector<HTMLElement>('.read');
    if (!read) return;
    const update = () => read.toggleAttribute('data-scrolled', read.scrollTop > 6);
    read.addEventListener('scroll', update, { passive: true });
    update();
  }
  // Click the card to enlarge it in a lightbox.
  function initZoom() {
    const btn = document.querySelector<HTMLElement>('.cardzoom');
    const dlg = document.querySelector<HTMLDialogElement>('.lightbox');
    if (!btn || !dlg) return;
    btn.addEventListener('click', () => dlg.showModal());
    dlg.addEventListener('click', (e) => { if (e.target === dlg) dlg.close(); });
    dlg.querySelector('.lightbox__close')?.addEventListener('click', () => dlg.close());
  }
  if (!(window as any).__cardInit) {
    (window as any).__cardInit = true;
    document.addEventListener('astro:page-load', () => { initReadFade(); initZoom(); });
  }
</script>

<style>
  .detail { display: flex; flex-direction: column; flex: 1; min-height: 0; }
  .back {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-60);
    text-decoration: none;
    margin-bottom: 1.6rem;
    flex: none;
  }
  .back:hover { color: var(--house); }

  /* text left (scrolls), card right (static) */
  .cols {
    display: grid;
    grid-template-columns: 1fr clamp(300px, 38%, 440px);
    gap: clamp(1.8rem, 4.5vw, 4rem);
    flex: 1;
    min-height: 0;
  }

  /* — left reading column: the scroll region — */
  .read {
    min-height: 0;
    overflow-y: auto;
    padding-right: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    /* always fade the bottom edge (near the pager); the top fades in only
       once scrolled, via --top-fade toggled by data-scrolled */
    --top-fade: 0px;
    transition: --top-fade 0.18s ease;
    mask-image: linear-gradient(to bottom, transparent 0, #000 var(--top-fade), #000 calc(100% - 30px), transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 var(--top-fade), #000 calc(100% - 30px), transparent 100%);
  }
  .read[data-scrolled] { --top-fade: 18px; }
  .read > * { max-width: 58ch; }

  .chead { display: flex; flex-direction: column; }
  .chead__eyebrow { margin-bottom: 0.7rem; }
  .chead__name {
    font-size: var(--fs-xl);
    line-height: 1.02;
    letter-spacing: 0.01em;
    margin: 0;
    color: var(--ink);
  }
  .chead__sub { margin: 0.5rem 0 0; font-size: var(--fs-md); color: var(--ink-60); }

  .rblock { display: flex; flex-direction: column; gap: 0.4rem; }
  .rblock__body { margin: 0; font-family: var(--font-name); font-size: var(--fs-base); line-height: 1.6; color: var(--ink); }

  .flavor { margin: 0.2rem 0 0; padding-top: 1.3rem; border-top: 1px solid var(--ink-30); display: flex; gap: 0.7rem; }
  .flavor__mark { color: var(--house); font-size: var(--fs-sm); line-height: 1.7; }
  .flavor p { margin: 0; font-size: var(--fs-md); line-height: 1.5; color: var(--ink-60); }

  .why { margin-top: 0.2rem; padding-top: 1.3rem; border-top: 1px solid var(--ink-30); display: flex; flex-direction: column; gap: 0.6rem; padding-bottom: 0.5rem; }
  .why__body { margin: 0; font-size: var(--fs-sm); line-height: 1.6; color: var(--ink-60); }

  /* — right card column: the card + its (clickable) keyword tags — */
  /* the card column fills the row height; the card scales to fit so it's
     never cut when the viewport is shorter than it (tags stay visible) */
  .cardcol { align-self: stretch; display: flex; flex-direction: column; gap: 1rem; min-height: 0; padding-bottom: clamp(0.5rem, 2.5vh, 1.2rem); }

  /* click-to-zoom; sits at its natural size (tags right below it) but
     shrinks to fit when the viewport is shorter than the card */
  .cardzoom {
    position: relative;
    flex: 0 1 auto;
    min-height: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
  }
  .cardzoom :global(.tile) {
    width: auto; height: auto;
    max-width: 100%; max-height: 100%;
    aspect-ratio: auto;
    display: flex;
  }
  .cardzoom :global(.tile__plate) {
    width: auto; height: auto;
    max-width: 100%; max-height: 100%;
    object-fit: contain;
    filter: var(--card-lift-lg);
  }
  .cardzoom:focus-visible { outline: 2px solid var(--house); outline-offset: 6px; }
  .cardzoom__hint {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-ui);
    font-size: var(--fs-2xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-60);
    background: color-mix(in srgb, var(--cream) 82%, transparent);
    border: 1px solid var(--ink-30);
    border-radius: 999px;
    padding: 0.18rem 0.5rem;
    opacity: 0;
    transition: opacity 140ms ease;
    pointer-events: none;
  }
  .cardzoom:hover .cardzoom__hint,
  .cardzoom:focus-visible .cardzoom__hint { opacity: 1; }

  .lightbox {
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    inset: 0;
    margin: 0;
    border: none;
    padding: 0;
    background: transparent;
    align-items: center;
    justify-content: center;
  }
  .lightbox[open] { display: flex; }
  .lightbox::backdrop { background: rgba(27, 34, 51, 0.6); backdrop-filter: blur(2px); }
  .lightbox__img {
    max-width: 92vw;
    max-height: 88dvh;
    width: auto;
    height: auto;
    display: block;
    filter: var(--card-lift-lg);
  }
  .lightbox__close {
    position: fixed;
    top: 1.2rem;
    right: 1.4rem;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid rgba(239, 232, 218, 0.5);
    background: rgba(27, 34, 51, 0.4);
    color: var(--cream);
    font-size: 1rem;
    cursor: pointer;
  }
  .lightbox__close:hover { background: rgba(27, 34, 51, 0.7); }
  .kw { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .kw-tag {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--fs-2xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-60);
    text-decoration: none;
    border: 1px solid var(--ink-30);
    border-radius: 999px;
    padding: 0.22rem 0.6rem;
    transition: border-color 140ms ease, color 140ms ease;
  }
  .kw-tag:hover { color: var(--house); border-color: var(--house); }
  .kw-tag--lead { color: var(--house); border-color: var(--house); }

  .share { margin: 0.4rem 0 0; display: flex; gap: 0.9rem; align-items: flex-start; padding-top: 1.1rem; border-top: 1px solid var(--ink-30); }
  .share__img { display: block; border: 1px solid var(--ink-30); height: auto; flex: none; }
  .share__copy { display: flex; flex-direction: column; gap: 0.4rem; }
  .share__hint { font-family: var(--font-ui); font-size: var(--fs-xs); line-height: 1.5; color: var(--ink-60); }

  /* — pinned pager — */
  .pager {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--ink);
  }
  .pager__link { display: flex; flex-direction: column; gap: 0.25rem; text-decoration: none; color: var(--ink); min-width: 0; }
  .pager__link--next { text-align: right; align-items: flex-end; }
  .pager__name { font-size: var(--fs-sm); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 40vw; }
  .pager__link:hover .pager__name { color: var(--house); }

  @media (max-width: 720px) {
    .cols { grid-template-columns: 1fr; }
    .read { overflow: visible; mask-image: none; -webkit-mask-image: none; padding-right: 0; }
    .cardcol { order: -1; max-width: 300px; }
  }
</style>
