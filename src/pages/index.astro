---
import Layout from '../components/Layout.astro';
import WindowChrome from '../components/WindowChrome.astro';
import FilterRail from '../components/FilterRail.astro';
import CardTile from '../components/CardTile.astro';
import ProgressStrip from '../components/ProgressStrip.astro';
import { majors, minorsBySuit, suitOrder, type Card } from '../lib/cards';
import { SITE, SUITS } from '../config';
import { withBase } from '../lib/url';

const sections: { title: string; sub: string; cards: Card[] }[] = [
  { title: 'Major Arcana', sub: 'The career, as an arc — 0 to XXI.', cards: majors },
  ...suitOrder.map((s) => ({
    title: SUITS[s].label,
    sub: SUITS[s].domain,
    cards: minorsBySuit[s],
  })),
];
---

<Layout title={`${SITE.name} · ${SITE.tagline}`}>
  <main class="shell">
    <WindowChrome>
      <h1 class="sr-only">{SITE.name} — the deck</h1>
      <div class="gallery">
        <FilterRail />

        <div class="gallery__main">
          {sections.map((sec) => (
            <section class="deck-section" data-section>
              <header class="section-head">
                <h2 class="section-head__title t-name">{sec.title}</h2>
                <span class="section-head__sub label">{sec.sub}</span>
                <span class="section-head__rule" aria-hidden="true"></span>
                <span class="section-head__count label">{sec.cards.length}</span>
              </header>
              <div class="grid">
                {sec.cards.map((c) => (
                  <CardTile
                    name={c.name}
                    suit={c.suit}
                    ready={c.ready}
                    artHref={c.artThumb ?? c.artHref}
                    backHref={c.backThumb ?? c.backHref}
                    href={withBase(`cards/${c.id}/`)}
                    transitionName={`card-${c.id}`}
                  />
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>

      <ProgressStrip />
    </WindowChrome>
  </main>
</Layout>

<style>
  .gallery {
    display: grid;
    grid-template-columns: 132px 1fr;
    gap: clamp(1.2rem, 3vw, 2.6rem);
    align-items: start;
  }
  .gallery__main { display: flex; flex-direction: column; gap: 2.6rem; min-width: 0; }

  .section-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 0.4rem 0.9rem;
    margin-bottom: 1.1rem;
  }
  .section-head__title { font-size: 1.15rem; color: var(--ink); }
  .section-head__sub { grid-row: 2; grid-column: 1 / -1; color: var(--ink-60); }
  .section-head__rule {
    align-self: center;
    height: 1px;
    background: var(--ink-30);
  }
  .section-head__count { color: var(--ink-60); }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(132px, 1fr));
    gap: clamp(0.8rem, 1.6vw, 1.3rem);
  }

  @media (max-width: 680px) {
    .gallery { grid-template-columns: 1fr; }
    .grid { grid-template-columns: repeat(auto-fill, minmax(108px, 1fr)); }
  }
</style>
